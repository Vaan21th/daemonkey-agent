# =========================================================================
# Daemonkey · 配置你的 LLM API key
# -------------------------------------------------------------------------
# 把这个文件复制成 .env（没有扩展名前缀），填上你的 key。
# .env 不会被提交（.gitignore 拦着）。
#
# Daemonkey 跑在你自己的 LLM key 上（BYOK）。挑下面一种填。
# =========================================================================


# ---- 方式 A：国内中转 / OpenAI 兼容代理（大陆用户最稳）----
# 常见 base_url：
#   OpenRouter:  https://openrouter.ai/api/v1
#   PPIO:        https://api.ppinfra.com/v3/openai
#   AiHubMix:    https://aihubmix.com/v1
# 常见 model： anthropic/claude-sonnet-4.5 / deepseek-chat / ...
OPUS_API_KEY=
OPUS_BASE_URL=https://openrouter.ai/api/v1
OPUS_MODEL=anthropic/claude-sonnet-4.5


# ---- 方式 B：Anthropic 官方直连（境外网络通畅时）----
# 完整版支持；当前『相遇』原型走 OpenAI 兼容协议，先用上面方式 A。
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx


# ---- 通用可选 ----
# 每轮回复的最大 token 数
OPUS_MAX_TOKENS=2000
