# git 钩子是 bash 脚本·必须 LF —— CRLF 会让 bash 报 "\r: command not found"·钩子静默失效
tools/git-hooks/pre-commit text eol=lf
*.sh text eol=lf

# 二进制·不做换行 / 编码转换（Daemonkey.exe 进仓库·属开箱即用资产）
*.exe binary
*.ico binary
*.png binary

# 品牌签名校验对 brand.json 的【原始字节】做 RSA-SHA256（卷七十五防篡改）。
# git 默认会对文本做 CRLF↔LF 转换 → 字节漂移 → 验签失败 → 正规 clone / Download ZIP
# 的包被误判成"非官方版"（0.5.2a 修复）。标 -text 钉死换行符，让所有人拿到的字节
# 与作者签名时完全一致。改 brand.json 后必须用私钥重签 brand.sig。
assets/brand.json -text
